# ---------------------------------------------------------------------------
# Docker environment for assets.i-portal.me (used by docker-compose.yml)
#
#   cp .env.docker.example .env
#   docker compose up -d --build
#
# These values are read by Docker Compose for variable substitution and are
# passed into the containers. The app entrypoint generates APP_KEY for you.
# ---------------------------------------------------------------------------

APP_NAME=assets.i-portal.me
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080

# Host port the app is published on (http://localhost:<WEB_PORT>)
WEB_PORT=8080

# Database (a fresh MySQL "latest" container is provisioned automatically)
DB_DATABASE=assets
DB_USERNAME=assets
DB_PASSWORD=change_me_app
DB_ROOT_PASSWORD=change_me_root
# Host port MySQL is published on (for local DB tools); set empty to disable
DB_EXPOSED_PORT=3306

# Laravel drivers
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Admin auto-created on first boot. You log in with ADMIN_USERNAME (NOT the
# email). Leave EMAIL/PASSWORD blank to skip and create one manually later with
# `docker compose exec app php artisan make:admin`.
ADMIN_NAME=Admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
